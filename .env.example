# 이 파일은 '예시'다. 복사해서 .env 로 만들고 실제 값을 채운다:  cp .env.example .env
# .env 는 .gitignore 로 커밋되지 않으며, 코드가 시작할 때 자동으로 읽는다(load_dotenv).
# 배포 환경에서는 .env 대신 클라우드가 실제 환경변수를 주입해도 된다(그게 우선).

# --- 필수: Qwen Cloud (DashScope) API 키 ---
# 코드는 키를 환경변수/.env 에서만 읽으며, 절대 하드코딩하지 않는다.
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# --- 선택: 사용할 Qwen 모델 (안 적으면 아래 기본값 사용) ---
# 쿼터 소진 등으로 모델을 바꾸고 싶을 때만 주석을 풀고 값을 지정한다. 자동 전환은 하지 않는다.
# MNEMOSURE_MODEL_BRAIN=qwen3.7-plus-2026-05-26
# MNEMOSURE_MODEL_FLASH=qwen3.5-flash
# MNEMOSURE_MODEL_EMBED=text-embedding-v4
# MNEMOSURE_MODEL_RERANK=qwen3-rerank
