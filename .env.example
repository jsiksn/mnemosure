# 이 파일은 '예시'다. 복사해서 .env 로 만들고 실제 값을 채운다:  cp .env.example .env
# .env 는 .gitignore 로 커밋되지 않으며, 코드가 시작할 때 자동으로 읽는다(load_dotenv).
# 배포 환경에서는 .env 대신 클라우드가 실제 환경변수를 주입해도 된다(그게 우선).

# --- 필수: OpenRouter API 키 (https://openrouter.ai/keys) ---
# 코드는 키를 환경변수/.env 에서만 읽으며, 절대 하드코딩하지 않는다.
OPENROUTER_API_KEY=sk-or-your-key-here

# --- 선택: 다른 OpenAI 호환 게이트웨이 사용 시 ---
# MNEMOSURE_BASE_URL=https://your-gateway/v1
# MNEMOSURE_API_KEY=your-gateway-key

# --- 선택: 사용할 모델 (안 적으면 아래 기본값 사용) ---
# 어느 역할이든 OpenRouter 모델 id로 자유 교체. 자동 전환은 하지 않는다.
# MNEMOSURE_MODEL_BRAIN=qwen/qwen3.7-plus
# MNEMOSURE_MODEL_FLASH=qwen/qwen3.5-flash-02-23
# MNEMOSURE_MODEL_EMBED=baai/bge-m3
# MNEMOSURE_MODEL_RERANK=cohere/rerank-4-fast

# --- 선택: rerank 끄기(코사인 폴백) / 로컬 임베딩 ---
# MNEMOSURE_RERANK=off
# MNEMOSURE_EMBED_PROVIDER=local          # pip install "mnemosure[local]" 필요
# MNEMOSURE_MODEL_EMBED_LOCAL=intfloat/multilingual-e5-large
